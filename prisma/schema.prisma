// Configuração do Banco
datasource db {
  provider = "mysql" // ou "postgresql"
  url      = env("DATABASE_URL")
}

// Gerador do Cliente (o que usamos no código Node)
generator client {
  provider = "prisma-client-js"
}

// Modelo de Usuário
model User {
  id        String   @id @default(uuid()) // ID único universal
  name      String
  email     String   @unique // Índice único para busca rápida
  phone     String
  password  String
  createdAt DateTime @default(now()) // Data de cadastro automática
  updatedAt DateTime @updatedAt // Atualiza sempre que o registro mudar
  logins    login[]

  @@map("users") // Nome da tabela no banco de dados (em minúsculo/plural)
}

//Modelo de Login
model login {
  id        String   @id @default(uuid()) // É boa prática toda tabela ter seu próprio ID
  token     String   @db.Text
  createdAt DateTime @default(now()) // Data de criação automática

  user_id String // ID único universal
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("login") // Nome da tabela no banco de dados (em minúsculo/plural)
}

//Modelo Token invalidado
model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @db.Text
  createdAt DateTime @default(now())

  @@map("token_blacklist")
}
