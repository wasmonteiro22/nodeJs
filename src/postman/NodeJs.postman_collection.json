				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"",
									"// Acessa o primeiro item [0] da lista de tokens e pega a propriedade 'token'",
									"const accessToken = response.tokens[0].token;",
									"",
									"pm.environment.set(\"TOKEN\", \"Bearer \"+accessToken);",
									"",
									"console.log(\"Token gravado com sucesso:\", accessToken);",
									"",
									"const refreshToken = response.tokens[1].refresh_token;",
									"pm.environment.set(\"REFRESH_TOKEN\", \"Bearer \"+refreshToken);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
